<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>GesPhone — {% block title %}{% endblock %}</title>

  <!-- Bootstrap 5 CDN -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <!-- MDI Icons -->
  <link rel="stylesheet" href="{{ asset('assets/vendors/mdi/css/materialdesignicons.min.css') }}">
  <!-- DataTables -->
  <link href="{{ asset('assets/datatables/datatables.min.css') }}" rel="stylesheet">
  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

  <style>
    *, *::before, *::after { box-sizing: border-box; }

    body {
      font-family: 'Inter', sans-serif;
      background: #f4f6fb;
      margin: 0;
      color: #212529;
    }

    /* ════ NAVBAR ════ */
    #topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: 60px;
      background: #fff;
      border-bottom: 1px solid #e9ecef;
      display: flex;
      align-items: center;
      z-index: 1000;
      padding: 0;
    }
    #topbar .brand {
      width: 250px;
      min-width: 250px;
      display: flex;
      align-items: center;
      padding: 0 24px;
      border-right: 1px solid #e9ecef;
      height: 100%;
    }
    #topbar .brand span {
      font-size: 1.2rem;
      font-weight: 700;
      color: #3b5bdb;
      letter-spacing: .08em;
    }
    #topbar .topbar-right {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 24px;
    }
    #topbar .welcome {
      font-size: .9rem;
      color: #495057;
    }
    #topbar .welcome strong {
      color: #212529;
      font-weight: 600;
    }
    #topbar .role-badge {
      display: inline-block;
      background: #e7edff;
      color: #3b5bdb;
      font-size: .7rem;
      font-weight: 600;
      padding: 2px 10px;
      border-radius: 20px;
      margin-left: 8px;
    }
    #topbar .user-avatar {
      width: 36px; height: 36px;
      border-radius: 50%;
      background: #3b5bdb;
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-weight: 700;
      font-size: .9rem;
    }

    /* ════ SIDEBAR ════ */
    #sidebar {
      position: fixed;
      top: 60px; left: 0;
      width: 250px;
      height: calc(100vh - 60px);
      background: #fff;
      border-right: 1px solid #e9ecef;
      overflow-y: auto;
      overflow-x: hidden;
      z-index: 999;
      padding: 16px 0 32px;
    }
    #sidebar::-webkit-scrollbar { width: 4px; }
    #sidebar::-webkit-scrollbar-thumb { background: #dee2e6; border-radius: 4px; }

    .sidebar-category {
      font-size: .65rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: .12em;
      color: #adb5bd;
      padding: 20px 20px 6px;
    }
    .sidebar-link {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 9px 16px;
      margin: 1px 8px;
      border-radius: 8px;
      color: #495057;
      text-decoration: none;
      font-size: .88rem;
      font-weight: 500;
      transition: background .15s, color .15s;
      cursor: pointer;
    }
    .sidebar-link:hover {
      background: #f1f3f9;
      color: #3b5bdb;
    }
    .sidebar-link.active {
      background: #e7edff;
      color: #3b5bdb;
      font-weight: 600;
    }
    .sidebar-link i {
      font-size: 1.1rem;
      width: 20px;
      text-align: center;
      color: #868e96;
      flex-shrink: 0;
    }
    .sidebar-link:hover i,
    .sidebar-link.active i {
      color: #3b5bdb;
    }
    .sidebar-link .arrow {
      margin-left: auto;
      font-size: .75rem;
      color: #ced4da;
      transition: transform .2s;
    }
    .sidebar-link.expanded .arrow {
      transform: rotate(90deg);
    }
    .sidebar-submenu-wrapper {
      max-height: 0;
      overflow: hidden;
      transition: max-height .25s ease;
    }
    .sidebar-submenu-wrapper.open {
      max-height: 300px;
    }
    .sidebar-submenu {
      list-style: none;
      padding: 0;
      margin: 0;
    }
    .sidebar-submenu .sidebar-link {
      padding: 7px 16px 7px 46px;
      font-size: .83rem;
      font-weight: 400;
      color: #6c757d;
    }
    .sidebar-submenu .sidebar-link:hover {
      color: #3b5bdb;
      background: #f1f3f9;
    }
    .sidebar-divider {
      border: none;
      border-top: 1px solid #f1f3f5;
      margin: 8px 16px;
    }

    /* ════ MAIN ════ */
    #main {
      margin-left: 250px;
      padding-top: 60px;
      min-height: 100vh;
    }
    #page-header {
      background: #fff;
      border-bottom: 1px solid #e9ecef;
      padding: 12px 28px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    #page-header .breadcrumb-title {
      font-size: .85rem;
      font-weight: 600;
      color: #3b5bdb;
      border-bottom: 2px solid #3b5bdb;
      padding-bottom: 4px;
    }
    #page-content {
      padding: 24px 28px;
    }

    /* ════ CARDS ════ */
    .card {
      border: none !important;
      border-radius: 12px !important;
      box-shadow: 0 1px 6px rgba(0,0,0,.07) !important;
    }

    /* ════ TABLES ════ */
    .table thead th {
      font-size: .8rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: #6c757d;
      border-bottom: 1px solid #e9ecef;
    }
  </style>
</head>

<body>

<!-- NAVBAR -->
<nav id="topbar">
  <div class="brand">
    <span>GESPHONE</span>
  </div>
  <div class="topbar-right">
    <div class="welcome">
      Bienvenue, <strong>{{ app.user.nom }} {{ app.user.prenom }}</strong>
      <span class="role-badge">{% if is_granted('ROLE_RESPONSABLE') %}Responsable{% else %}Tenancier{% endif %}</span>
    </div>
    <div class="dropdown">
      <div class="user-avatar" data-bs-toggle="dropdown" style="cursor:pointer;">
        {{ app.user.nom|first|upper }}
      </div>
      <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" style="min-width:180px;">
        <li class="px-3 py-2 text-muted" style="font-size:.8rem;">{{ app.user.username }}</li>
        <li><hr class="dropdown-divider my-1"></li>
        <li><a class="dropdown-item" href="{{ path('app_logout') }}"><i class="mdi mdi-power me-2 text-danger"></i>Déconnexion</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- SIDEBAR -->
<nav id="sidebar">

  {% set r = app.request.get('_route') %}

  <a href="{{ path('app_admin') }}" class="sidebar-link {{ r == 'app_admin' ? 'active' : '' }}">
    <i class="mdi mdi-view-dashboard-outline"></i> Tableau de bord
  </a>

  <div class="sidebar-category">Boutique</div>

  {% set articlesOpen = r starts with 'app_produit' %}
  <a class="sidebar-link {{ articlesOpen ? 'expanded' : '' }}" data-target="m-articles" href="#">
    <i class="mdi mdi-package-variant-closed"></i> Articles <i class="mdi mdi-chevron-right arrow"></i>
  </a>
  <div class="sidebar-submenu-wrapper {{ articlesOpen ? 'open' : '' }}" id="m-articles">
    <ul class="sidebar-submenu">
      <li><a class="sidebar-link" href="{{ path('app_produit_new') }}">Ajouter</a></li>
      <li><a class="sidebar-link" href="{{ path('app_produit_index') }}">Liste</a></li>
    </ul>
  </div>

  {% set ventesOpen = r starts with 'app_vente' %}
  <a class="sidebar-link {{ ventesOpen ? 'expanded' : '' }}" data-target="m-ventes" href="#">
    <i class="mdi mdi-cart-outline"></i> Ventes <i class="mdi mdi-chevron-right arrow"></i>
  </a>
  <div class="sidebar-submenu-wrapper {{ ventesOpen ? 'open' : '' }}" id="m-ventes">
    <ul class="sidebar-submenu">
      <li><a class="sidebar-link" href="{{ path('app_vente_new') }}">Nouvelle vente</a></li>
      <li><a class="sidebar-link" href="{{ path('app_vente_index') }}">Liste des ventes</a></li>
    </ul>
  </div>

  {% if is_granted('ROLE_RESPONSABLE') %}
  {% set approOpen = r starts with 'app_approvisionnement' %}
  <a class="sidebar-link {{ approOpen ? 'expanded' : '' }}" data-target="m-appro" href="#">
    <i class="mdi mdi-truck-delivery-outline"></i> Approvisionnements <i class="mdi mdi-chevron-right arrow"></i>
  </a>
  <div class="sidebar-submenu-wrapper {{ approOpen ? 'open' : '' }}" id="m-appro">
    <ul class="sidebar-submenu">
      <li><a class="sidebar-link" href="{{ path('app_approvisionnement_new') }}">Ajouter</a></li>
      <li><a class="sidebar-link" href="{{ path('app_approvisionnement_index') }}">Liste</a></li>
    </ul>
  </div>
  {% endif %}

  <div class="sidebar-category">Paramètres</div>

  {% set catOpen = r starts with 'app_categorie' %}
  <a class="sidebar-link {{ catOpen ? 'expanded' : '' }}" data-target="m-cat" href="#">
    <i class="mdi mdi-tag-multiple-outline"></i> Catégories <i class="mdi mdi-chevron-right arrow"></i>
  </a>
  <div class="sidebar-submenu-wrapper {{ catOpen ? 'open' : '' }}" id="m-cat">
    <ul class="sidebar-submenu">
      <li><a class="sidebar-link" href="{{ path('app_categorie_new') }}">Ajouter</a></li>
      <li><a class="sidebar-link" href="{{ path('app_categorie_index') }}">Liste</a></li>
    </ul>
  </div>

  {% set clientOpen = r starts with 'app_client' %}
  <a class="sidebar-link {{ clientOpen ? 'expanded' : '' }}" data-target="m-clients" href="#">
    <i class="mdi mdi-account-group-outline"></i> Clients <i class="mdi mdi-chevron-right arrow"></i>
  </a>
  <div class="sidebar-submenu-wrapper {{ clientOpen ? 'open' : '' }}" id="m-clients">
    <ul class="sidebar-submenu">
      <li><a class="sidebar-link" href="{{ path('app_client_index') }}">Liste des clients</a></li>
    </ul>
  </div>

  {% if is_granted('ROLE_RESPONSABLE') %}
  <div class="sidebar-category">Administration</div>

  {% set usersOpen = r starts with 'app_utilisateur' or r == 'app_inscription' %}
  <a class="sidebar-link {{ usersOpen ? 'expanded' : '' }}" data-target="m-users" href="#">
    <i class="mdi mdi-account-cog-outline"></i> Comptes utilisateurs <i class="mdi mdi-chevron-right arrow"></i>
  </a>
  <div class="sidebar-submenu-wrapper {{ usersOpen ? 'open' : '' }}" id="m-users">
    <ul class="sidebar-submenu">
      <li><a class="sidebar-link" href="{{ path('app_inscription') }}">Ajouter</a></li>
      <li><a class="sidebar-link" href="{{ path('app_utilisateur_index') }}">Liste des comptes</a></li>
    </ul>
  </div>
  {% endif %}

  <hr class="sidebar-divider mt-3">

  <a href="{{ path('app_logout') }}" class="sidebar-link" style="color:#dc3545;">
    <i class="mdi mdi-power" style="color:#dc3545;"></i> Déconnexion
  </a>

</nav>

<!-- MAIN CONTENT -->
<div id="main">

  <div id="page-header">
    <span class="breadcrumb-title">{% block breadcrumb %}{% endblock %}</span>
    <div>{% block bouton %}{% endblock %}</div>
  </div>

  <div id="page-content">

    {% for type, messages in app.flashes %}
      {% for message in messages %}
        <div class="alert alert-{{ type }} alert-dismissible fade show mb-3" role="alert">
          {{ message }}
          <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
      {% endfor %}
    {% endfor %}

    <div class="card">
      <div class="card-body p-4">
        {% block body %}{% endblock %}
      </div>
    </div>

  </div>
</div>

<!-- jQuery -->
<script src="https://cdn.jsdelivr.net/npm/jquery@3.7.1/dist/jquery.min.js"></script>
<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<!-- DataTables -->
<script src="{{ asset('assets/datatables/datatables.min.js') }}"></script>
<script>
$(document).ready(function () {
  if ($('#myTable').length) {
    $('#myTable').DataTable();
  }
});
</script>

<!-- Sidebar collapse toggle maison -->
<script>
document.querySelectorAll('.sidebar-link[data-target]').forEach(function(link) {
  link.addEventListener('click', function(e) {
    e.preventDefault();
    var targetId = this.getAttribute('data-target');
    var target = document.getElementById(targetId);
    if (!target) return;
    var isOpen = target.classList.contains('open');
    // Fermer tous les autres
    document.querySelectorAll('.sidebar-submenu-wrapper.open').forEach(function(el) {
      el.classList.remove('open');
    });
    document.querySelectorAll('.sidebar-link[data-target]').forEach(function(l) {
      l.classList.remove('expanded');
    });
    if (!isOpen) {
      target.classList.add('open');
      this.classList.add('expanded');
    }
  });
});
</script>

{% block javascripts %}{% endblock %}

</body>
</html>
