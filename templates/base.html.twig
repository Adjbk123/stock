<!DOCTYPE html>
<html lang="en">

<head>
  <!-- Required meta tags -->
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
  <title>GesPhone {% block title %} {% endblock %} </title>
  <!-- plugins:css -->
  <link rel="stylesheet" href="{{ asset('assets/vendors/feather/feather.css') }}">
  <link rel="stylesheet" href="{{ asset('assets/vendors/mdi/css/materialdesignicons.min.css') }}">
  <link rel="stylesheet" href="{{ asset('assets/vendors/ti-icons/css/themify-icons.css') }}">
  <link rel="stylesheet" href="{{ asset('assets/vendors/typicons/typicons.css') }}">
  <link rel="stylesheet" href="{{ asset('assets/vendors/simple-line-icons/css/simple-line-icons.css') }}">
  <link rel="stylesheet" href="{{ asset('assets/vendors/css/vendor.bundle.base.css') }}">
  <!-- endinject -->
  <!-- Plugin css for this page -->
  <link rel="stylesheet" href="{{ asset('assets/js/select.dataTables.min.css') }}">
  <!-- End plugin css for this page -->
  <!-- inject:css -->
  <link rel="stylesheet" href="{{ asset('assets/css/vertical-layout-light/style.css') }}">
  <!-- endinject -->
  <link rel="shortcut icon" href="{{ asset('assets/images/favicon.png') }}" />
  <link href="{{ asset('assets/datatables/datatables.min.css') }}" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    /* ── Base ── */
    body {
      font-family: 'Montserrat', sans-serif;
      background-color: #f4f7fc;
    }

    /* ── Navbar ── */
    .navbar.default-layout {
      background: #ffffff !important;
      box-shadow: 0 1px 4px rgba(0,0,0,.08) !important;
      border-bottom: 1px solid #e9ecef !important;
      height: 63px;
    }
    .navbar .navbar-brand-wrapper {
      background: #ffffff !important;
      border-right: 1px solid #e9ecef !important;
      width: 260px !important;
      min-width: 260px !important;
    }
    .navbar .navbar-brand-wrapper h3 {
      color: #3b5bdb !important;
      font-size: 1.3rem;
      font-weight: 700;
      letter-spacing: .1em;
    }
    .navbar .navbar-menu-wrapper {
      background: #ffffff !important;
      width: calc(100% - 260px) !important;
    }
    .welcome-text {
      font-size: .95rem !important;
      color: #495057;
    }
    .welcome-text span {
      color: #212529 !important;
    }

    /* ── Layout ── */
    .page-body-wrapper {
      min-height: calc(100vh - 63px) !important;
      padding-top: 63px !important;
    }
    .sidebar {
      background: #ffffff !important;
      border-right: 1px solid #e9ecef !important;
      box-shadow: none !important;
      min-height: calc(100vh - 63px) !important;
      width: 260px !important;
      min-width: 260px !important;
      position: fixed !important;
      top: 63px !important;
      left: 0 !important;
      overflow: hidden !important;
      z-index: 100;
      padding-top: 12px !important;
    }
    .main-panel {
      margin-left: 260px !important;
      width: calc(100% - 260px) !important;
      min-height: calc(100vh - 63px) !important;
      background: #f4f7fc !important;
    }
    .content-wrapper {
      background: #f4f7fc !important;
      padding: 24px !important;
    }
    .sidebar .nav .nav-item .nav-link {
      color: #495057 !important;
      border-radius: 8px;
      margin: 2px 10px;
      transition: all .18s;
    }
    .sidebar .nav .nav-item .nav-link:hover {
      background: #f1f3f9 !important;
      color: #3b5bdb !important;
    }
    .sidebar .nav .nav-item.active > .nav-link {
      background: #e7edff !important;
      color: #3b5bdb !important;
      font-weight: 600;
    }
    .sidebar .nav .nav-item .nav-link .menu-icon,
    .sidebar .nav .nav-item .nav-link i {
      color: #868e96 !important;
    }
    .sidebar .nav .nav-item .nav-link:hover .menu-icon,
    .sidebar .nav .nav-item.active > .nav-link .menu-icon {
      color: #3b5bdb !important;
    }
    .sidebar .nav .nav-item.nav-category {
      color: #adb5bd !important;
      font-size: .68rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      font-weight: 700;
      padding: 18px 22px 6px;
    }
    .sidebar .nav .sub-menu .nav-item .nav-link {
      color: #6c757d !important;
      font-size: .85rem;
    }
    .sidebar .nav .sub-menu .nav-item .nav-link:hover {
      color: #3b5bdb !important;
      background: #f1f3f9 !important;
    }
    .sidebar .nav .menu-arrow {
      color: #adb5bd !important;
    }

    /* ── Content ── */
    .main-panel {
      background: #f4f7fc !important;
    }
    .content-wrapper {
      background: #f4f7fc !important;
    }
    .home-tab .nav-tabs .nav-link.active {
      color: #1a253f !important;
      font-weight: 600;
      border-bottom: 2px solid #4e73df;
    }
    .home-tab .nav-tabs .nav-link {
      color: #6c757d;
    }

    /* ── Cards globales ── */
    .card {
      border: none !important;
      box-shadow: 0 2px 8px rgba(0,0,0,.06);
      border-radius: 10px !important;
    }

    /* ── Menu title ── */
    .menu-title {
      font-family: 'Montserrat', sans-serif !important;
      font-size: .9rem !important;
    }
  </style>

</head>
<body>
<div class="container-scroller">

  <!-- partial:partials/_navbar.html -->
  {{ include('partials/_navbar.html.twig') }}
  <!-- partial -->
  <div class="container-fluid page-body-wrapper">
    <!-- partial:partials/_settings-panel.html -->

    {{ include('partials/_settings-panel.html.twig') }}
    <!-- partial -->
    <!-- partial:partials/_sidebar.html -->
    {{ include('partials/_sidebar.html.twig') }}
    <!-- partial -->
    <div class="main-panel">
      <div class="content-wrapper">
        <div class="row">
          <div class="col-sm-12">
            <div class="home-tab">
              <div class="d-sm-flex align-items-center justify-content-between border-bottom">
                <ul class="nav nav-tabs" role="tablist">
                  <li class="nav-item">
                    <a class="nav-link active ps-0" id="home-tab" data-bs-toggle="tab" href="javascript:void(0);" role="tab" aria-controls="overview" aria-selected="true">{% block breadcrumb %}{% endblock %}</a>
                  </li>
                  <li class="nav-item">

                    <a class="nav-link border-0" id="more-tab" data-bs-toggle="tab" href="javascript:void(0);" role="tab" aria-selected="false">{{ block('title') }}</a>
                  </li>
                </ul>
                <div>
                  <div class="btn-wrapper">
                    {% block bouton %}

                    {% endblock %}
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        {% for type, messages in app.flashes %}
          {% for message in messages %}
            <div class="alert alert-{{ type }} alert-dismissible fade show" role="alert">
              {{ message }}
              <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
          {% endfor %}
        {% endfor %}

        <div class="card">
          <div class="card-body">
            {% block body %}

            {% endblock %}
          </div>

        </div>



      </div>

      <!-- content-wrapper ends -->
      <!-- partial:partials/_footer.html -->
      {{ include('partials/_footer.html.twig') }}
      <!-- partial -->
    </div>

    <!-- main-panel ends -->
  </div>
  <!-- page-body-wrapper ends -->
</div>
<!-- container-scroller -->



<!-- plugins:js -->
<script src="{{ asset('assets/vendors/js/vendor.bundle.base.js') }}"></script>
  <!-- endinject -->
  <!-- Plugin js for this page -->
    <script src="{{ asset('assets/datatables/datatables.min.js') }}"></script>
  <script src="{{ asset('assets/vendors/chart.js/Chart.min.js') }}"></script>
  <script src="{{ asset('assets/vendors/bootstrap-datepicker/bootstrap-datepicker.min.js') }}"></script>
  <script src="{{ asset('assets/vendors/progressbar.js/progressbar.min.js') }}"></script>

  <!-- End plugin js for this page -->
  <!-- inject:js -->
  <script src="{{ asset('assets/js/off-canvas.js') }}"></script>
  <script src="{{ asset('assets/js/hoverable-collapse.js') }}"></script>
  <script src="{{ asset('assets/js/template.js') }}"></script>
  <script src="{{ asset('assets/js/settings.js') }}"></script>
  <script src="{{ asset('assets/js/todolist.js') }}"></script>
  <!-- endinject -->
  <!-- Custom js for this page-->
  <script src="{{ asset('assets/js/jquery.cookie.js') }}" type="text/javascript"></script>
  <script src="{{ asset('assets/js/dashboard.js') }}"></script>
  <script src="{{ asset('assets/js/Chart.roundedBarCharts.js') }}"></script>
  <!-- End custom js for this page-->

<script >
$(document).ready( function () {
    $('#myTable').DataTable();
} );
</script>

{% block javascripts %}

  {% endblock %}

</body>

</html>

